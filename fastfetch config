{
  "$schema": "https://github.com/fastfetch-cli/fastfetch/raw/dev/doc/json_schema.json",

  "logo": {
    "type": "file",
    "source": "~/.config/fastfetch/penguin.txt",
    "padding": {
      "top": 1,
      "left": 2
    }
  },

  "display": {
    "separator": "  ",
    "color": "cyan"
  },

  "modules": [
    "title",
    "separator",

    {
      "type": "os",
      "key": "❄ OS"
    },
    {
      "type": "kernel",
      "key": "Kernel"
    },
    {
      "type": "uptime",
      "key": "Uptime"
    },

    "separator",

    {
      "type": "wm",
      "key": "WM"
    },
    {
      "type": "terminal",
      "key": "Term"
    },
    {
      "type": "shell",
      "key": "Shell"
    },

    "separator",

    {
      "type": "cpu",
      "key": "CPU"
    },
    {
      "type": "gpu",
      "key": "GPU"
    },
    {
      "type": "memory",
      "key": "RAM"
    },

    "separator",

    {
      "type": "packages",
      "key": "Packages"
    }
  ]
}
